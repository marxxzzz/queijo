---
---

<!-- Fora do header: fixed em relação ao viewport (evita stacking context do Flatsome) -->
<div id="cart-popup" class="mfp-hide astro-cart-popup-root" aria-hidden="true">
	<div class="cart-popup-inner inner-padding cart-popup-inner--sticky">
		<button
			type="button"
			id="cart-popup-close"
			class="button outline is-small"
			style="position:absolute;top:8px;right:8px;z-index:2;"
			aria-label="Fechar carrinho"
		>
			×
		</button>
		<div class="cart-popup-title text-center">
			<span class="heading-font uppercase">Carrinho</span>
			<div class="is-divider"></div>
		</div>
		<div class="widget_shopping_cart">
			<div class="widget_shopping_cart_content">
				<div id="astro-cart-empty" class="ux-mini-cart-empty flex flex-row-col text-center pt pb">
					<div class="ux-mini-cart-empty-icon">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 17 19" style="opacity:.1;height:80px;">
							<path
								d="M8.5 0C6.7 0 5.3 1.2 5.3 2.7v2H2.1c-.3 0-.6.3-.7.7L0 18.2c0 .4.2.8.6.8h15.7c.4 0 .7-.3.7-.7v-.1L15.6 5.4c0-.3-.3-.6-.7-.6h-3.2v-2c0-1.6-1.4-2.8-3.2-2.8zM6.7 2.7c0-.8.8-1.4 1.8-1.4s1.8.6 1.8 1.4v2H6.7v-2zm7.5 3.4 1.3 11.5h-14L2.8 6.1h2.5v1.4c0 .4.3.7.7.7.4 0 .7-.3.7-.7V6.1h3.5v1.4c0 .4.3.7.7.7s.7-.3.7-.7V6.1h2.6z"
								fill-rule="evenodd"
								clip-rule="evenodd"
								fill="currentColor"></path>
						</svg>
					</div>
					<p class="woocommerce-mini-cart__empty-message empty">Nenhum produto no carrinho.</p>
					<p class="return-to-shop">
						<a class="button primary wc-backward" href="/#produtos" data-cart-close>Retornar para a loja</a>
					</p>
				</div>
				<ul
					id="astro-mini-cart-list"
					class="woocommerce-mini-cart cart_list product_list_widget astro-mini-cart"
				>
				</ul>
				<div id="astro-cart-footer" class="astro-cart-footer" style="padding-bottom: 15px;" hidden>
					<div class="cart-subtotal-row flex-row mb-half">
						<div class="flex-col flex-grow">
							<span class="subtotal-label uppercase">Subtotal:</span>
						</div>
						<div class="flex-col">
							<strong id="cart-popup-subtotal" class="subtotal-amount">R$ 0,00</strong>
						</div>
					</div>
					<div class="is-divider mb-half" style="max-width:100%;"></div>
					<a href="/carrinho/" class="button primary expand uppercase" style="margin-bottom: 8px;" data-cart-close>Ver Carrinho</a>
					<a href="/carrinho/" class="button primary expand uppercase" style="margin-bottom: 0;" data-cart-close>Finalização de Compra</a>
				</div>
			</div>
		</div>
	</div>
</div>
