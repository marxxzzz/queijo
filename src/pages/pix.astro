---
// Página de pagamento Pix (visual alinhado ao gateway de referência; cobrança via PUBLIC_PIX_API_URL)
---
<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, user-scalable=no" />
		<title>Pagamento Pix | Queijaria Oficial</title>
		<link rel="stylesheet" href="/assets/pix-payment-clone.css" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			/*
			 * Patch: pix-payment-clone.css referencia #info-card e #details-card (sem sufixo).
			 * O markup local usa variantes #info-card-mobile / #info-card-web / #details-card-*.
			 * Usamos seletores de atributo [id^="..."] para cobrir todas as variantes de uma vez.
			 */

			/* ── Base: padding e flex ─────────────────────────── */
			.content-info [id^="info-card"],
			.content-info [id^="details-card"] {
				padding-right: 15px;
				padding-left: 15px;
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
			}
			@media (min-width: 768px) {
				.content-info [id^="info-card"],
				.content-info [id^="details-card"] {
					padding-right: 0;
					padding-left: 0;
				}
				.content-info [id^="details-card"].d-none-fade-web,
				.content-info [id^="info-card"].d-none-fade-web {
					display: block !important;
				}
			}

			/* ── Esconder details-card quando colapsado ──────── */
			.content-info [id^="details-card"].d-none-fade,
			.content-info [id^="details-card"].d-none-fade-web {
				display: none !important;
			}
			/* Esconder info-card-mobile quando colapsado */
			.content-info #info-card-mobile.d-none-fade {
				display: none !important;
			}

			/* ── Details-card: produto ───────────────────────── */
			.content-info [id^="details-card"] .product-content {
				margin-top: 20px;
				height: 70px;
				overflow: hidden;
				cursor: pointer;
			}
			.content-info [id^="details-card"] .product-wrapper {
				padding-bottom: 10px;
				height: 60px;
				max-width: 100%;
				display: flex;
				flex-direction: row;
				flex-wrap: nowrap;
				align-items: flex-end;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}
			.content-info [id^="details-card"].d-none-fade-web .product-wrapper {
				justify-content: center;
			}
			@media (min-width: 768px) {
				.content-info [id^="details-card"].d-none-fade-web .product-wrapper {
					justify-content: flex-start !important;
				}
			}
			.content-info [id^="details-card"] .product-wrapper > .item {
				margin-right: 17px;
				width: 53px;
				height: 53px;
				position: relative;
				border-radius: 8px;
				background: #fff;
				flex-shrink: 0;
			}
			.content-info [id^="details-card"] .product-wrapper > .item:last-of-type {
				margin-right: 0;
			}
			.content-info [id^="details-card"] .product-wrapper > .item > img {
				height: 53px;
				width: 53px;
				border-radius: 8px;
				object-fit: cover;
				cursor: pointer;
				display: block;
			}

			/* ── Info-card: instruções de pagamento ──────────── */
			.content-info [id^="info-card"] > .instructions-purchase {
				margin-top: 30px;
				height: 42px;
				width: 100%;
				display: flex;
				flex-direction: row;
				justify-content: flex-start;
				align-items: center;
			}
			.content-info [id^="info-card"] > .instructions-purchase > span {
				margin-right: 17px;
				height: 42px;
				min-width: 42px;
				border-radius: 100%;
				background: #41c286;
				display: flex;
				justify-content: center;
				align-items: center;
				align-self: center;
				flex-shrink: 0;
			}
			.content-info [id^="info-card"] > .instructions-purchase > span > img {
				height: 20px;
				object-fit: contain;
			}
			.content-info [id^="info-card"] > .instructions-purchase > p {
				flex: 1;
				min-width: 0;
				text-align: left;
				font: normal normal normal 14px/16px Inter, sans-serif;
				letter-spacing: 0;
				color: #797979;
			}
			/* Garantir visibilidade das instruções quando o card está expandido */
			.content-info [id^="info-card"]:not(.d-none-fade) > .instructions-purchase,
			.content-info [id^="info-card"].d-none-fade-web > .instructions-purchase {
				display: flex;
			}

			/* ── Misc ────────────────────────────────────────── */
			.key-pix-input {
				box-sizing: border-box;
				max-width: 100%;
			}
			.content-pix .pix-wrapper img.qrcode {
				max-width: 100%;
				height: auto;
				display: inline-block;
			}
			body {
				font-family: Inter, sans-serif;
				background: #f2f2f2;
			}

			/* ── Espaçamento interno do card Pix ─────────────── */
			.content-pix .pix-when-active {
				display: flex;
				flex-direction: column;
				align-items: center;
				padding: 20px 16px 20px;
				gap: 0;
			}
			.content-pix .pix-when-active .message-copie {
				margin-top: 0;
				margin-bottom: 14px;
				line-height: 1.5;
			}
			.content-pix .pix-when-active .key-pix-input {
				width: 100%;
				margin-bottom: 12px;
			}
			.content-pix .pix-when-active .button-pix {
				width: 100%;
				margin-bottom: 0;
			}
			.content-pix .pix-wrapper {
				margin-bottom: 16px;
			}

			/* ── Ajax loader (overlay, igual à referência) ───── */
			.ajax-loader {
				visibility: hidden;
				background-color: rgba(255, 255, 255, 0.8);
				position: fixed;
				width: 100vw;
				height: 100vh;
				top: 0;
				left: 0;
				z-index: 1000;
				text-align: center;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				gap: 0.75rem;
			}

			/* Oculta o QR code enquanto o src estiver vazio */
			img.qrcode:not([src]), img.qrcode[src=""] {
				display: none !important;
			}

			/* Countdown abaixo do botão */
			.pix-countdown-label {
				box-sizing: border-box;
				font-size: 13px;
				color: #555;
				margin-top: 14px;
				margin-bottom: 0;
				text-align: center;
				width: 100%;
				padding: 10px;
				background: #fafafa;
				border: 1.5px dashed #e0e0e0;
				border-radius: 8px;
			}
			.pix-countdown-label span {
				font-weight: 700;
				color: #b20000;
			}

			/* Força auto height na estrutura do card para evitar sobreposição */
			.card.thanks,
			.content-pix-mobile,
			.content-pix-web,
			.content-pix,
			.pix-when-active {
				height: auto !important;
				min-height: max-content !important;
				overflow: visible !important;
			}

			/* ── Mensagens de erro / API ─────────────────────── */
			.pix-api-missing,
			.pix-error-msg {
				display: none;
				max-width: 640px;
				margin: 1rem auto;
				padding: 1rem 1.25rem;
				background: #fff3cd;
				border: 1px solid #ffc107;
				border-radius: 8px;
				color: #856404;
				font-size: 14px;
				line-height: 1.5;
			}
			.pix-error-msg {
				background: #f8d7da;
				border-color: #f5c6cb;
				color: #721c24;
			}

			/* ── Estado de expiração do PIX ──────────────────── */
			.content-pix .pix-when-expired {
				display: none;
			}
			.content-pix.is-pix-expired .pix-when-active {
				display: none !important;
			}
			.content-pix.is-pix-expired .pix-when-expired {
				display: block !important;
			}
			.thk-topbar img {
				display: block;
			}
		</style>
	</head>
	<body>
		<p class="pix-api-missing">
			<strong>API Pix:</strong> crie um ficheiro <code>.env</code> na raiz do projeto com
			<code>PUBLIC_BUCKPAY_TOKEN=seu_token_buckpay</code>
			(ver integração em <code>src/scripts/pix-api.ts</code>).
		</p>
		<p class="pix-error-msg" role="alert"></p>

		<div class="thk-topbar" style="background-color: white; margin-bottom:10px; padding:0">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-lg-11">
						<a href="/" style="display:inline-block">
							<img
								src="https://loja-oficial-online.shop/wp-content/uploads/2025/11/freepik__assistant__66891.png"
								alt="Queijaria Oficial"
								style="max-height:44px; margin:15px 0 15px 15px"
							/>
						</a>
					</div>
				</div>
			</div>

			<!-- Standard Footer consistency -->
			<div class="chk-footer" style="text-align: center; padding: 28px 20px; color: #999; font-size: 12px;">
				<div class="chk-footer-pay-label" style="font-size: 13px; font-weight: 600; color: #777; margin-bottom: 10px;">Plataforma Segura Padrão</div>
				<div class="chk-footer-pix-icon" style="background: transparent; width: auto; height: 30px; margin-bottom: 8px;">
					<img src="/assets/img/soon-pix.svg" alt="Pagamento via PIX" style="height: 100%; display: block; margin: 0 auto;" />
				</div>
				<p>&copy; 2026 Queijaria Oficial</p>
			</div>
		</div>

		<div class="container">
			<div class="ajax-loader">
				<img style="width: 120px" src="/assets/img/pix-loading.svg" alt="" class="img-responsive" />
				<span>Gerando Pix…</span>
			</div>

			<div class="d-md-none">
				<div class="thk-topbar text-center">
					<h1 class="thk-topbar-title">
						Falta pouco! Para finalizar a compra, efetue o pagamento com PIX!
					</h1>
				</div>

				<div class="row no-gutters justify-content-center">
					<div class="col-12" style="max-width: 650px">
						<div class="card thanks">
							<div class="content-pix content-pix-mobile col-12 text-center">
								<div class="pix-when-active">
									<div class="pix-wrapper">
										<img
											class="qrcode"
											src=""
											alt="QrCode Pix"
											style="width:200px;height:200px;display:block;margin:0 auto;"
										/>
									</div>
									<div class="hr-horizontal-100"></div>
									<p class="message-copie">
										Copie a chave abaixo e utilize a <br /> opção <span>PIX Copia e Cola:</span>
									</p>
									<input type="text" class="key-pix-input copy_digitable_line" value="" readonly />
									<button type="button" class="btn buy-btn button-pix copy_digitable_line">
										<img src="/assets/img/copy.svg" alt="" width="18" height="18" />
										<span> COPIAR CÓDIGO</span>
									</button>
								</div>
								<div class="pix-when-expired">
									<p class="countdown color-red">Ops!, tente novamente</p>
									<div class="hr-horizontal-100"></div>
									<p class="message-copie message-copie-expired">
										Copie a chave abaixo e utilize a <br /> opção <span>PIX Copia e Cola:</span>
									</p>
									<button type="button" class="btn buy-btn button-pix button-pix-expired js-regenerate-pix">
										<img src="https://pay.pague-shopee.site/assets/img/reload.svg" alt="" />
										GERAR NOVO PIX
									</button>
								</div>
							</div>
						</div>
					</div>

					<div class="col-12 mt-0 pl-0 pr-0" style="max-width: 650px">
						<div class="content-info text-left">
							<p class="countdown pix-countdown-label" style="margin-bottom:14px;text-align:center">
								O código expira em: &nbsp;<span class="pix-countdown-remaining">10:00</span>
							</p>
							<p class="message-purchase d-block">
								Valor a ser pago: &nbsp; <span class="cart-total-value">R$ 0,00</span>
							</p>

							<div class="info-wrapper">
								<div class="collapse-button">
									<h2 class="info-title info-purchase">Instruções para pagamento</h2>
									<span class="d-block"><img src="/assets/img/down.svg" alt="" /></span>
								</div>
								<div class="hr-horizontal-100"></div>
								<div id="info-card-mobile" class="">
									<div class="instructions-purchase">
										<span><img src="/assets/img/app-indicator.svg" alt="" /></span>
										<p>
											Após copiar o código, abra seu aplicativo de pagamento onde você utiliza o Pix.
										</p>
									</div>
									<div class="instructions-purchase">
										<span><img src="/assets/img/qr-code.svg" alt="" /></span>
										<p>
											Escolha a opção <span>PIX Copia e Cola</span> e insira o código copiado.
										</p>
									</div>
									<div class="instructions-purchase">
										<span><img src="/assets/img/check-circle-line-white.svg" alt="" /></span>
										<p>Confirme as informações e finalize sua compra.</p>
									</div>
								</div>
							</div>

							<div class="details-wrapper">
								<div class="collapse-button">
									<h2 class="info-title details-purchase">Detalhes da compra:</h2>
									<span class="d-block"><img src="/assets/img/down.svg" alt="" /></span>
								</div>
								<div class="hr-horizontal-100"></div>
								<div id="details-card-mobile" class="">
									<div class="product-content" style="position: relative;">
										<div class="asScrollable-container" style="height: 87px;">
											<div
												class="product-wrapper asScrollable-content"
												style="height: 70px; justify-content: flex-start"
											>
											</div>
										</div>
									</div>
								</div>
							</div>

							<div class="clearfix"></div>
							<div class="soon-wrapper justify-content-center">
								<img src="/assets/img/soon-pix.svg" alt="" />
								<div class="hr-vertical d-flex justify-content-center align-items-center align-self-center">
								</div>
								<img src="/assets/img/safe-environment.svg" alt="" />
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="d-none d-md-block">
				<div class="thk-topbar text-center">
					<h1 class="thk-topbar-title">
						Falta pouco! Para finalizar a compra, escaneie o QR Code abaixo.
					</h1>
				</div>
				<div class="clearfix"></div>

				<div class="row no-gutters justify-content-center">
					<div class="col-12 col-md-6">
						<div class="card thanks">
							<div class="content-pix content-pix-web col-12 text-center">
								<div class="pix-when-active">
									<div class="pix-wrapper">
										<img
											class="qrcode"
											src=""
											alt="QrCode Pix"
											style="width:200px;height:200px;display:block;margin:0 auto;"
										/>
									</div>
									<div class="hr-horizontal-100"></div>
									<p class="message-copie">
										Se preferir, pague com a opção &nbsp; <span>PIX Copia e Cola:</span>
									</p>
									<input type="text" class="key-pix-input copy_digitable_line" value="" readonly />
									<button type="button" class="btn buy-btn copy_digitable_line button-pix">
										<img src="/assets/img/copy.svg" alt="" />
										<span> COPIAR CÓDIGO</span>
									</button>
								</div>
								<div class="pix-when-expired">
									<p class="countdown color-red">Ops!, tente novamente</p>
									<div class="hr-horizontal-100"></div>
									<button type="button" class="btn buy-btn js-regenerate-pix">
										<img src="https://pay.pague-shopee.site/assets/img/reload.svg" alt="" />
										GERAR NOVO PIX
									</button>
								</div>
							</div>
						</div>
						<p class="countdown pix-countdown-label" style="margin-top:14px;text-align:center">
							O código expira em: &nbsp;<span class="pix-countdown-remaining">10:00</span>
						</p>
					</div>

					<div class="col-12 col-md-6 col-lg-5 mt-0 pl-md-4 pl-lg-5">
						<div class="content-info text-left">
							<div class="details-wrapper mt-md-0 order-2 order-md-0">
								<div class="collapse-button">
									<h2 class="info-title details-purchase">Detalhes da compra:</h2>
									<span class="d-block d-md-none"><img src="/assets/img/down.svg" alt="" /></span>
								</div>
								<div class="hr-horizontal-100"></div>
								<p class="message-purchase text-left d-none d-md-block">
									Valor total: &nbsp; <span class="cart-total-value">R$ 0,00</span>
								</p>
								<div id="details-card-web" class="d-none-fade-web">
									<div class="product-content" style="position: relative;">
										<div class="asScrollable-container" style="height: 87px;">
											<div
												class="product-wrapper asScrollable-content"
												style="height: 70px; justify-content: flex-start"
											>
											</div>
										</div>
									</div>
								</div>
							</div>

							<div class="info-wrapper order-1 order-md-1">
								<div class="collapse-button">
									<h2 class="info-title info-purchase">Instruções para pagamento</h2>
									<span class="d-block d-md-none"><img src="/assets/img/down.svg" alt="" /></span>
								</div>
								<div class="hr-horizontal-100"></div>
								<div id="info-card-web" class="d-none-fade-web">
									<div class="instructions-purchase">
										<span><img src="/assets/img/app-indicator.svg" alt="" /></span>
										<p>Abra o app do seu banco e entre no ambiente Pix</p>
									</div>
									<div class="instructions-purchase">
										<span><img src="/assets/img/qr-code.svg" alt="" /></span>
										<p>
											Escolha <span>Pagar com QR Code</span> e aponte a câmera para o código ao lado.
										</p>
									</div>
									<div class="instructions-purchase">
										<span><img src="/assets/img/check-circle-line-white.svg" alt="" /></span>
										<p>Confirme as informações e finalize sua compra.</p>
									</div>
								</div>
							</div>

							<div class="clearfix clearfix-auto order-4"></div>
							<div class="hr-horizontal-100 d-none d-md-block order-5"></div>
							<div class="soon-wrapper order-6">
								<img src="/assets/img/soon-pix.svg" alt="" />
								<div class="hr-vertical d-flex justify-content-center align-items-center align-self-center">
								</div>
								<img src="/assets/img/safe-environment.svg" alt="" />
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="half"></div>
			<div class="clearfix"></div>
		</div>

		<script>
			import { initPixCheckoutPage } from "../scripts/pix-checkout-page";
			initPixCheckoutPage();
		</script>
	</body>
</html>
