    <script is:inline>
        /* ===== STEP NAVIGATION ===== */
        function goToStep(step) {
            document.querySelectorAll('.chk-step-panel').forEach(p => p.classList.remove('active'));
            document.getElementById('step-' + step).classList.add('active');
            document.querySelectorAll('.chk-step').forEach((el, idx) => {
                const s = idx + 1;
                el.classList.remove('active', 'done');
                if (s < step) el.classList.add('done');
                if (s === step) el.classList.add('active');
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function validateAndGo(nextStep) {
            const currentStep = nextStep - 1;
            const panel = document.getElementById('step-' + currentStep);
            const inputs = panel.querySelectorAll('input:not([type="checkbox"]), select');
            let hasError = false;
            let firstErrorElement = null;

            inputs.forEach(input => {
                if (input.id === 'email' && document.getElementById('noEmail').checked) return;
                if (input.id === 'receiver_name' && !document.getElementById('btn-collapse-receiver').checked) return;
                if (input.id === 'complement') return;
                if (input.id === 'number' && document.getElementById('noNumber') && document.getElementById('noNumber').checked) return;

                const val = input.value ? input.value.trim() : '';
                let inputHasError = false;

                if (input.tagName === 'SELECT') {
                    if (!val) { inputHasError = true; }
                } else if (!val || val.length < 2) {
                    inputHasError = true;
                }

                if (!inputHasError) {
                    if (input.id === 'document' && val.replace(/\D/g, '').length < 11) { inputHasError = true; }
                    if (input.id === 'zip_code' && val.replace(/\D/g, '').length < 8) { inputHasError = true; }
                }

                markError(input, inputHasError);
                if (inputHasError) {
                    hasError = true;
                    if (!firstErrorElement) firstErrorElement = input;
                }
            });

            if (!hasError) {
                goToStep(nextStep);
            } else if (firstErrorElement) {
                firstErrorElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(() => firstErrorElement.focus(), 600);
            }
        }

        function markError(input, hasError) {
            const fb = input.nextElementSibling;
            if (hasError) {
                input.classList.add('input-error');
                if (fb && fb.classList.contains('invalid-feedback')) fb.style.display = 'flex';
            } else {
                input.classList.remove('input-error');
                if (fb && fb.classList.contains('invalid-feedback')) fb.style.display = '';
            }
        }

        /* ===== MASKS ===== */
        function maskCPF(v) {
            v = v.replace(/\D/g,'');
            v = v.replace(/(\d{3})(\d)/,'$1.$2');
            v = v.replace(/(\d{3})(\d)/,'$1.$2');
            v = v.replace(/(\d{3})(\d{1,2})$/,'$1-$2');
            return v.substring(0,14);
        }
        function maskPhone(v) {
            v = v.replace(/\D/g,'');
            v = v.replace(/^(\d{2})(\d)/g,'($1) $2');
            v = v.replace(/(\d)(\d{4})$/,'$1-$2');
            return v.substring(0,15);
        }
        function maskCEP(v) {
            v = v.replace(/\D/g,'');
            v = v.replace(/^(\d{5})(\d)/,'$1-$2');
            return v.substring(0,9);
        }
        function maskCard(v) {
            v = v.replace(/\D/g,'');
            v = v.replace(/(\d{4})(?=\d)/g,'$1 ');
            return v.substring(0,19);
        }
        function maskExpiry(v) {
            v = v.replace(/\D/g,'');
            if (v.length >= 2) v = v.substring(0,2) + '/' + v.substring(2);
            return v.substring(0,5);
        }

        document.addEventListener('input', e => {
            if (e.target.id === 'document' || e.target.id === 'card_cpf') e.target.value = maskCPF(e.target.value);
            if (e.target.id === 'telephone') e.target.value = maskPhone(e.target.value);
            if (e.target.id === 'zip_code') {
                e.target.value = maskCEP(e.target.value);
                if (e.target.value.replace(/\D/g,'').length === 8) fetchAddress(e.target.value);
            }
            if (e.target.id === 'card_number') e.target.value = maskCard(e.target.value);
            if (e.target.id === 'card_expiry') e.target.value = maskExpiry(e.target.value);
        });

        document.addEventListener('change', e => {
            if (e.target.id === 'noEmail') {
                const emailInp = document.getElementById('email');
                emailInp.disabled = e.target.checked;
                if (e.target.checked) {
                    emailInp.classList.remove('input-error');
                    emailInp.value = '';
                }
            }
            if (e.target.id === 'btn-collapse-receiver') {
                document.getElementById('collapse-receiver').classList.toggle('show', e.target.checked);
            }
            if (e.target.id === 'noNumber') {
                const numInp = document.getElementById('number');
                numInp.disabled = e.target.checked;
                if (e.target.checked) {
                    numInp.classList.remove('input-error');
                    numInp.value = 'S/N';
                } else {
                    numInp.value = '';
                }
            }
        });

        /* ===== VIACEP ===== */
        async function fetchAddress(cep) {
            const clean = cep.replace(/\D/g,'');
            if (clean.length !== 8) return;
            try {
                const res = await fetch('https://viacep.com.br/ws/' + clean + '/json/');
                const data = await res.json();
                if (!data.erro) {
                    document.getElementById('street').value = data.logradouro || '';
                    document.getElementById('neighborhood').value = data.bairro || '';
                    document.getElementById('city').value = data.localidade || '';
                    document.getElementById('state').value = data.uf || '';
                    document.getElementById('number').focus();
                }
            } catch(e) { console.error('ViaCEP error', e); }
        }

        /* ===== PAYMENT TABS ===== */
        function switchPayTab(method) {
            ['pix','card','boleto'].forEach(m => {
                document.getElementById('tab-' + m).classList.toggle('active', m === method);
                document.getElementById('panel-' + m).classList.toggle('active', m === method);
            });
        }

        /* ===== CART TOGGLE (mobile) ===== */
        function toggleCart() {
            const body = document.getElementById('chk-cart-body');
            const chevron = document.getElementById('chk-cart-chevron');
            if (body) body.classList.toggle('open');
            if (chevron) chevron.classList.toggle('open');
        }

        const LOJA_CART_KEY = 'loja-oficial-cart-v1';
        function fmtBRL(n) {
            return 'R$ ' + Number(n).toFixed(2).replace('.', ',');
        }
        function escHtml(s) {
            return String(s)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }
        /* SVG inline = cores fiéis à referência; não depende de CDN */
        var chkQtyMinusSvg =
            '<svg class="chk-qty-ic" width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 12h14" stroke="#E30613" stroke-width="2.8" stroke-linecap="round"/></svg>';
        var chkQtyPlusSvg =
            '<svg class="chk-qty-ic" width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="#00A03E" stroke-width="2.8" stroke-linecap="round"/></svg>';

        /* ===== LOAD CART ===== */
        function loadCart() {
            const stored = localStorage.getItem(LOJA_CART_KEY);
            const cart = stored ? JSON.parse(stored) : [];
            const container = document.getElementById('chk-items-container');
            const badge = document.getElementById('chk-qty-badge');

            if (!cart || cart.length === 0) {
                container.innerHTML = '<div style="color:#aaa;font-size:13px;padding:10px 0;">Seu carrinho está vazio. <a href="/carrinho/">Ir ao carrinho</a></div>';
                if (badge) badge.innerText = '0';
                updateTotals();
                return;
            }

            let html = '';
            let qty = 0;

            cart.forEach((item, idx) => {
                qty += item.quantity;
                const title = item.title || item.name || 'Produto';
                const variant = item.variant ? String(item.variant) : '';
                const imgSrc = item.image ? escHtml(item.image) : '';
                const thumbBlock = item.image
                    ? '<div class="product-img-wrap"><img class="product-img" src="' + imgSrc + '" alt="" width="40" height="40" loading="lazy" decoding="async" onerror="this.onerror=null;this.style.visibility=\'hidden\';"></div>'
                    : '<div class="product-img-wrap"><div class="product-img-placeholder" aria-hidden="true"></div></div>';
                const variantBlock = variant
                    ? '<span class="info-small ellipsis-w">' + escHtml(variant) + '</span>'
                    : '';
                html += '<div class="product-list">' +
                    '<div class="product-grid">' +
                    '<div class="d-flex align-items-center">' + thumbBlock + '</div>' +
                    '<div>' +
                        '<span class="name_product_card ellipsis-h">' + escHtml(title) + '</span>' +
                        variantBlock +
                    '</div>' +
                    '<div class="d-flex align-items-center justify-content-end" style="margin-left:12px;">' +
                        '<div class="input-number" role="group" aria-label="Alterar quantidade" style="display:inline-flex;align-items:center;justify-content:space-between;min-width:94px;height:34px;padding:0 8px;gap:4px;border:1px solid #d8d8d8;border-radius:999px;background:#fff;">' +
                            '<button type="button" class="btn-sub" onclick="changeQty(' + idx + ', -1)" aria-label="Diminuir quantidade" style="all:unset;display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;cursor:pointer;line-height:0;">' + chkQtyMinusSvg + '</button>' +
                            '<span class="qty-value" style="display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:24px;text-align:center;font:600 15px/1 Inter,sans-serif;color:#141414;user-select:none;">' + item.quantity + '</span>' +
                            '<button type="button" class="btn-add" onclick="changeQty(' + idx + ', 1)" aria-label="Aumentar quantidade" style="all:unset;display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;cursor:pointer;line-height:0;">' + chkQtyPlusSvg + '</button>' +
                        '</div>' +
                    '</div>' +
                    '</div></div>';
            });

            container.innerHTML = html;
            if (badge) badge.innerText = String(qty);
            updateTotals();
        }

        function changeQty(idx, delta) {
            const stored = localStorage.getItem(LOJA_CART_KEY);
            const cart = stored ? JSON.parse(stored) : [];
            if (!cart[idx]) return;
            
            if (delta < 0) {
                if (cart[idx].quantity > 1) {
                    cart[idx].quantity -= 1;
                } else if (cart.length > 1) {
                    cart.splice(idx, 1);
                }
            } else {
                cart[idx].quantity += 1;
            }
            
            localStorage.setItem(LOJA_CART_KEY, JSON.stringify(cart));
            loadCart();
            try { window.dispatchEvent(new CustomEvent('loja-cart')); } catch (e) {}
        }

        function setQtyFromInput(idx, el) {
            var v = parseInt(el.value, 10);
            if (!Number.isFinite(v) || v < 1) v = 1;
            if (v > 99) v = 99;
            const stored = localStorage.getItem(LOJA_CART_KEY);
            const cart = stored ? JSON.parse(stored) : [];
            if (!cart[idx]) return;
            cart[idx].quantity = v;
            localStorage.setItem(LOJA_CART_KEY, JSON.stringify(cart));
            loadCart();
            try { window.dispatchEvent(new CustomEvent('loja-cart')); } catch (e) {}
        }
        window.setQtyFromInput = setQtyFromInput;

        function finalizePurchase() {
            const payload = {
                shippingBRL: selectedShippingValue,
                shippingMethod: window.__selectedShippingType || 'gratis',
                customer: {
                    email: (document.getElementById('email') || {}).value?.trim?.() || '',
                    telephone: (document.getElementById('telephone') || {}).value?.trim?.() || '',
                    name: (document.getElementById('name') || {}).value?.trim?.() || '',
                    document: (document.getElementById('document') || {}).value?.trim?.() || '',
                },
                shipping: {
                    zip_code: (document.getElementById('zip_code') || {}).value?.trim?.() || '',
                    street: (document.getElementById('street') || {}).value?.trim?.() || '',
                    number: (document.getElementById('number') || {}).value?.trim?.() || '',
                    complement: (document.getElementById('complement') || {}).value?.trim?.() || '',
                    neighborhood: (document.getElementById('neighborhood') || {}).value?.trim?.() || '',
                    city: (document.getElementById('city') || {}).value?.trim?.() || '',
                    state: (document.getElementById('state') || {}).value?.trim?.() || '',
                    receiver_name: (document.getElementById('receiver_name') || {}).value?.trim?.() || '',
                },
            };
            sessionStorage.setItem('loja-checkout-payload', JSON.stringify(payload));
            window.location.href = '/pix/';
        }

        /* ===== SHIPPING LOGIC ===== */
        let selectedShippingValue = 0;
        const allShippingCards = ['gratis', 'jadlog', 'sedex'];

        function selectShipping(type, value) {
            window.__selectedShippingType = type;
            selectedShippingValue = value;

            allShippingCards.forEach(id => {
                const card = document.getElementById('shipping-card-' + id);
                const radio = document.getElementById('shipping-radio-' + id);
                const dot = document.getElementById('shipping-dot-' + id);
                if (!card) return;

                if (id === type) {
                    card.style.border = '1.5px solid #6aa8e8';
                    card.style.boxShadow = '0 2px 10px rgba(106,168,232,0.18)';
                    card.style.background = '#f7fbff';
                    radio.style.border = '2px solid #6aa8e8';
                    dot.style.background = '#6aa8e8';
                } else {
                    card.style.border = '1.5px solid #dee2e6';
                    card.style.boxShadow = 'none';
                    card.style.background = '#fff';
                    radio.style.border = '2px solid #dee2e6';
                    dot.style.background = 'transparent';
                }
            });

            updateTotals();
        }

        function updateTotals() {
            const stored = localStorage.getItem(LOJA_CART_KEY);
            const cart = stored ? JSON.parse(stored) : [];
            let subtotal = 0;
            cart.forEach(item => {
                const price = Number(item.unitPrice != null ? item.unitPrice : (item.salePrice || item.regularPrice || 0));
                subtotal += price * item.quantity;
            });

            const freteEl = document.getElementById('chk-frete');
            const totalEl = document.getElementById('chk-total');
            const subtotalEl = document.getElementById('chk-subtotal');
            
            if (subtotalEl) subtotalEl.innerText = fmtBRL(subtotal);
            if (freteEl) freteEl.innerText = selectedShippingValue === 0 ? 'Grátis' : fmtBRL(selectedShippingValue);
            if (totalEl) totalEl.innerText = fmtBRL(subtotal + selectedShippingValue);
        }

        /* ===== GLOBAL EXPOSE ===== */
        window.goToStep = goToStep;
        window.validateAndGo = validateAndGo;
        window.switchPayTab = switchPayTab;
        window.changeQty = changeQty;
        window.toggleCart = toggleCart;
        window.finalizePurchase = finalizePurchase;
        window.selectShipping = selectShipping;

        function initCart() {
            loadCart();
            updateTotals();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initCart);
        } else {
            initCart();
        }
    </script>
    <!-- Vite HMR force v2 -->
</body>
</html>

