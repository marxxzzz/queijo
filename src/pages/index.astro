						<div id="col-1677921239" class="col medium-3 small-6 large-3">
							<div class="col-inner">
								<div class="icon-box featured-box icon-box-center text-center">
									<div class="icon-box-img" style="width: 25px">
										<div class="icon">
											<div class="icon-inner">
												<img
