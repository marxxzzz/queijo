---
import Layout from "../components/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProductCard from "../components/ProductCard.astro";
import products from "../data/products.json";
import type { Product } from "../lib/price";

const list = products as Product[];
const splitIdx = list.findIndex((p) => p.slug.startsWith("4-queijos-de-alagoa"));
const featured =
	splitIdx >= 0 ? list.slice(0, splitIdx) : list.slice(0, Math.ceil(list.length / 2));
const complement =
	splitIdx >= 0 ? list.slice(splitIdx) : list.slice(featured.length);

const heroSrc =
	"/images/wp-content/uploads/2026/01/2-slide-1766153988818-2516402732-49d6edf31ce051e28d132e30268171911766154001-1920-1920.webp";
const heroSrcSet = `${heroSrc} 1200w, /images/wp-content/uploads/2026/01/2-slide-1766153988818-2516402732-49d6edf31ce051e28d132e30268171911766154001-1920-1920-768x768.webp 768w, /images/wp-content/uploads/2026/01/2-slide-1766153988818-2516402732-49d6edf31ce051e28d132e30268171911766154001-1920-1920-510x510.webp 510w`;

const bannerJoin =
	"/images/wp-content/uploads/2025/11/1717783961_come_and_join.jpg";
---

<Layout
	title="Loja Oficial"
	description="Loja de queijos artesanais, kits e cestas — Ofertas imperdíveis."
	bodyClass="home"
>
	<SiteHeader />

	<main id="main" class="">
		<div id="content" role="main" class="content-area">
			<div id="gap-1595097585" class="gap-element clearfix hidden" style="display:block; height:auto;">
				<style is:global>
					#gap-1595097585 {
						padding-top: 30px;
					}
				</style>
			</div>

			<section class="section" id="section_546320785">
				<div class="section-bg fill"></div>
				<div class="section-content relative">
					<div class="row show-for-small" id="row-380588080">
						<div id="col-360811531" class="col medium-4 small-12 large-4">
							<div class="col-inner">
								<div class="img has-hover x md-x lg-x y md-y lg-y" id="image_68564829">
									<div class="img-inner dark">
										<picture>
											<source type="image/webp" srcset={heroSrcSet} sizes="100vw" />
											<img
												decoding="async"
												width="1200"
												height="1200"
												src={heroSrc}
												class="attachment-original size-original"
												alt=""
												fetchpriority="high"
											/>
										</picture>
									</div>
									<style is:global>
										#image_68564829 {
											width: 100%;
										}
									</style>
								</div>
							</div>
						</div>
					</div>
					<div class="row hide-for-small" id="row-hero-desktop">
						<div class="col small-12 large-12">
							<div class="col-inner">
								<div class="img has-hover" id="image_hero_desktop">
									<div class="img-inner dark">
										<picture>
											<source type="image/webp" srcset={heroSrcSet} sizes="100vw" />
											<img
												decoding="async"
												width="1200"
												height="1200"
												src={heroSrc}
												class="attachment-original size-original"
												alt=""
												fetchpriority="high"
											/>
										</picture>
									</div>
									<style is:global>
										#image_hero_desktop {
											width: 100%;
										}
									</style>
								</div>
							</div>
						</div>
					</div>
				</div>
				<style is:global>
					#section_546320785 {
						padding-top: 0;
						padding-bottom: 0;
					}
				</style>
			</section>

			<div class="row row-collapse align-center" id="row-898818082">
				<div id="col-47858755" class="col small-12 large-12">
					<div class="col-inner">
						<div id="text-2590770451" class="text">
							<p>Os mais pedidos!</p>
							<style is:global>
								#text-2590770451 {
									font-size: 1.5rem;
									line-height: 0.75;
									text-align: center;
								}
								@media (min-width: 550px) {
									#text-2590770451 {
										font-size: 1.5rem;
									}
								}
								@media (min-width: 850px) {
									#text-2590770451 {
										font-size: 1.7rem;
									}
								}
							</style>
						</div>
						<div
							class="row equalize-box large-columns-5 medium-columns-5 small-columns-2 row-small"
							id="produtos"
						>
							{featured.map((product, i) => (
								<ProductCard product={product} priority={i < 4} />
