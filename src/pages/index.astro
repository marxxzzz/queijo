													class="attachment-medium size-medium"
													alt=""
												/>
											</div>
										</div>
									</div>
									<div class="icon-box-text last-reset">
										<div id="text-1703419339" class="text">
											<h3>FRETE EXPRESSO</h3>
											<style is:global>
												#text-1703419339 {
													font-size: 0.85rem;
